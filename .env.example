# ---------- apps/web ----------
# Supabase (new API key architecture: publishable key for the browser, secret key server-only)
# Create both under "Settings → API Keys" in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...   # required for username sign-up (admin user creation) + invite/member admin paths

# Liveblocks secret (server-side) — used by /api/liveblocks-auth
LIVEBLOCKS_SECRET_KEY=

# Browser compile target. Leave empty to proxy via Next.js /api/compile (recommended locally).
NEXT_PUBLIC_COMPILER_URL=
# Server-side URL for the compile proxy (apps/web/app/api/compile)
COMPILER_URL=http://127.0.0.1:3001
# Shared bearer token used only between the web server and compiler service.
# Generate a production value with: openssl rand -hex 32
COMPILER_API_KEY=

# Dev-only test user. When set, /login renders a "Sign in as test user" button
# that bypasses email confirmation. Provision the user once via:
#   pnpm --filter web seed:test-user
TEST_USER_EMAIL=test@kursach.local
TEST_USER_PASSWORD=kursach-test-password

# ---------- apps/compiler ----------
COMPILER_PORT=3001
COMPILER_ALLOWED_ORIGIN=http://localhost:3000
COMPILER_MAX_SOURCE_BYTES=2097152
COMPILER_PASS_TIMEOUT_MS=60000
